# Client Environment Variables
# Copy this file to .env and fill in values for local development
# For Vercel, set these in: Project → Settings → Environment Variables

# URL of your deployed backend API (Render)
# Local dev:      http://localhost:5000/api
# Production:     https://your-app-name.onrender.com/api
VITE_API_URL=http://localhost:5000/api
