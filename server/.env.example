# Server Environment Variables
# Copy this file to .env and fill in your actual values
# For Render, set these in: Service → Environment → Add Variable

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/foodeasey?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Local dev:    http://localhost:5173
# Production:   https://your-app-name.vercel.app
# Both:         http://localhost:5173,https://your-app-name.vercel.app
CLIENT_URL=http://localhost:5173
